    instruction: "Update MediaForm component with the new space theme, colors, and capsule buttons."
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <motion.div \n      initial={{ opacity: 0 }}\n      animate={{ opacity: 1 }}\n      exit={{ opacity: 0 }}\n      className=\"fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4\"\n    >\n      <motion.div \n        initial={{ scale: 0.9, y: 20 }}\n        animate={{ scale: 1, y: 0 }}\n        className=\"bg-zinc-900 border border-zinc-800 rounded-[2rem] w-full max-w-xl overflow-hidden shadow-2xl\"\n      >\n        <div className=\"p-6 border-b border-zinc-800 flex justify-between items-center bg-zinc-900/50\">\n          <h2 className=\"text-xl font-semibold text-white\">Add New Media</h2>\n          <button onClick={onClose} className=\"p-2 hover:bg-zinc-800 rounded-full text-zinc-400 transition-colors\">\n            <X size={20} />\n          </button>\n        </div>\n\n        <form onSubmit={handleSubmit} className=\"p-8 space-y-6 max-h-[70vh] overflow-y-auto custom-scrollbar\">\n          {/* Media Type Selector */}\n          <div className=\"grid grid-cols-5 gap-2\">\n            {[\n              { id: MediaType.MOVIE, icon: <Film size={18} />, label: \'Movie\' },\n              { id: MediaType.SERIES, icon: <Tv size={18} />, label: \'Series\' },\n              { id: MediaType.DOCUMENTARY, icon: <Film size={18} />, label: \'Doc\' },\n              { id: MediaType.BOOK, icon: <Book size={18} />, label: \'Book\' },\n              { id: MediaType.GAME, icon: <Gamepad2 size={18} />, label: \'Game\' },\n            ].map((item) => (\n              <button\n                key={item.id}\n                type=\"button\"\n                onClick={() => setType(item.id)}\n                className={`flex flex-col items-center gap-2 p-3 rounded-2xl border transition-all ${\n                  type === item.id \n                    ? \'bg-white border-white text-zinc-900\' \n                    : \'bg-zinc-800/50 border-zinc-700 text-zinc-400 hover:border-zinc-500\'\n                }`}\n              >\n                {item.icon}\n                <span className=\"text-[10px] font-bold uppercase tracking-wider\">{item.label}</span>\n              </button>\n            ))}\n          </div>\n\n          <div className=\"space-y-4\">\n            <div>\n              <label className=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">Title</label>\n              <input\n                required\n                type=\"text\"\n                value={title}\n                onChange={(e) => setTitle(e.target.value)}\n                placeholder=\"Enter title...\"\n                className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors\"\n              />\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div>\n                <label className=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">Status</label>\n                <select\n                  value={status}\n                  onChange={(e) => setStatus(e.target.value as MediaStatus)}\n                  className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors appearance-none\"\n                >\n                  <option value={MediaStatus.PLANNED}>Planned</option>\n                  <option value={MediaStatus.IN_PROGRESS}>In Progress</option>\n                  <option value={MediaStatus.COMPLETED}>Completed</option>\n                  <option value={MediaStatus.DROPPED}>Dropped</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">Rating</label>\n                <div className=\"flex items-center h-[50px] gap-1 px-2\">\n                  {[1, 2, 3, 4, 5].map((s) => (\n                    <button\n                      key={s}\n                      type=\"button\"\n                      onClick={() => setRating(s)}\n                      className=\"p-1\"\n                    >\n                      <Star \n                        size={20} \n                        className={`${s <= rating ? \'fill-white text-white\' : \'text-zinc-700\'}`} \n                      />\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            {/* Dynamic Fields */}\n            <AnimatePresence mode=\"wait\">\n              <motion.div\n                key={type}\n                initial={{ opacity: 0, y: 10 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -10 }}\n                className=\"space-y-4\"\n              >\n                {isVisualMedia && (\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"flex items-center gap-2 text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">\n                        <Calendar size={12} /> Watch Date\n                      </label>\n                      <input\n                        type=\"date\"\n                        value={watchDate}\n                        onChange={(e) => setWatchDate(e.target.value)}\n                        className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"flex items-center gap-2 text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">\n                        <Monitor size={12} /> Platform\n                      </label>\n                      <input\n                        type=\"text\"\n                        value={platform}\n                        onChange={(e) => setPlatform(e.target.value)}\n                        placeholder=\"Netflix, HBO...\"\n                        className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors\"\n                      />\n                    </div>\n                  </div>\n                )}\n\n                {isInteractiveMedia && (\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"flex items-center gap-2 text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">\n                        <Calendar size={12} /> Start Date\n                      </label>\n                      <input\n                        type=\"date\"\n                        value={startDate}\n                        onChange={(e) => setStartDate(e.target.value)}\n                        className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"flex items-center gap-2 text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">\n                        <Calendar size={12} /> End Date\n                      </label>\n                      <input\n                        type=\"date\"\n                        value={endDate}\n                        onChange={(e) => setEndDate(e.target.value)}\n                        className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors\"\n                      />\n                    </div>\n                  </div>\n                )}\n\n                {type === MediaType.GAME && (\n                  <div>\n                    <label className=\"flex items-center gap-2 text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">\n                      <Cpu size={12} /> Console\n                    </label>\n                    <input\n                      type=\"text\"\n                      value={consoleName}\n                      onChange={(e) => setConsoleName(e.target.value)}\n                      placeholder=\"PS5, Xbox, Switch...\"\n                      className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors\"\n                    />\n                  </div>\n                )}\n              </motion.div>\n            </AnimatePresence>\n\n            <div>\n              <label className=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2\">Notes</label>\n              <textarea\n                value={notes}\n                onChange={(e) => setNotes(e.target.value)}\n                placeholder=\"Thoughts, quotes, or reminders...\"\n                rows={3}\n                className=\"w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-zinc-500 transition-colors resize-none\"\n              />\n            </div>\n          </div>\n\n          <div className=\"pt-4 flex gap-3\">\n            <button\n              type=\"button\"\n              onClick={onClose}\n              className=\"flex-1 px-6 py-4 bg-zinc-800 text-white rounded-2xl font-bold hover:bg-zinc-700 transition-all\"\n            >\n              Cancel\n            </button>\n            <button\n              type=\"submit\"\n              className=\"flex-1 px-6 py-4 bg-white text-zinc-900 rounded-2xl font-bold hover:bg-zinc-200 transition-all shadow-lg shadow-white/5\"\n            >\n              Save Item\n            </button>\n          </div>\n        </form>\n      </motion.div>\n    </motion.div>\n  );"
        replacement_content: "  return (\n    <motion.div \n      initial={{ opacity: 0 }}\n      animate={{ opacity: 1 }}\n      exit={{ opacity: 0 }}\n      className=\"fixed inset-0 bg-space-bg/60 backdrop-blur-md z-[100] flex items-center justify-center p-4\"\n    >\n      <motion.div \n        initial={{ scale: 0.9, y: 20 }}\n        animate={{ scale: 1, y: 0 }}\n        className=\"bg-space-bg border border-white/10 rounded-[3rem] w-full max-w-xl overflow-hidden shadow-2xl shadow-rocket-fire/10\"\n      >\n        <div className=\"p-8 border-b border-white/5 flex justify-between items-center bg-white/5\">\n          <h2 className=\"text-2xl font-black text-off-white uppercase tracking-tighter\">New Artifact</h2>\n          <button onClick={onClose} className=\"p-2 hover:bg-white/10 rounded-full text-zinc-400 transition-colors\">\n            <X size={24} />\n          </button>\n        </div>\n\n        <form onSubmit={handleSubmit} className=\"p-10 space-y-8 max-h-[70vh] overflow-y-auto custom-scrollbar\">\n          {/* Media Type Selector */}\n          <div className=\"grid grid-cols-5 gap-3\">\n            {[\n              { id: MediaType.MOVIE, icon: <Film size={20} />, label: \'Movie\' },\n              { id: MediaType.SERIES, icon: <Tv size={20} />, label: \'Series\' },\n              { id: MediaType.DOCUMENTARY, icon: <Film size={20} />, label: \'Doc\' },\n              { id: MediaType.BOOK, icon: <Book size={20} />, label: \'Book\' },\n              { id: MediaType.GAME, icon: <Gamepad2 size={20} />, label: \'Game\' },\n            ].map((item) => (\n              <button\n                key={item.id}\n                type=\"button\"\n                onClick={() => setType(item.id)}\n                className={`flex flex-col items-center gap-2 p-4 rounded-3xl border transition-all duration-300 ${\n                  type === item.id \n                    ? \'bg-rocket-fire border-rocket-fire text-white shadow-[0_0_15px_rgba(255,77,0,0.4)]\' \n                    : \'bg-white/5 border-white/10 text-zinc-400 hover:border-white/30\'\n                }`}\n              >\n                {item.icon}\n                <span className=\"text-[9px] font-black uppercase tracking-[0.15em]\">{item.label}</span>\n              </button>\n            ))}\n          </div>\n\n          <div className=\"space-y-6\">\n            <div>\n              <label className=\"block text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">Identification</label>\n              <input\n                required\n                type=\"text\"\n                value={title}\n                onChange={(e) => setTitle(e.target.value)}\n                placeholder=\"Artifact Title...\"\n                className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors placeholder:text-zinc-600\"\n              />\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">Status</label>\n                <select\n                  value={status}\n                  onChange={(e) => setStatus(e.target.value as MediaStatus)}\n                  className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors appearance-none cursor-pointer\"\n                >\n                  <option value={MediaStatus.PLANNED}>Planned</option>\n                  <option value={MediaStatus.IN_PROGRESS}>In Progress</option>\n                  <option value={MediaStatus.COMPLETED}>Completed</option>\n                  <option value={MediaStatus.DROPPED}>Dropped</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">Rating</label>\n                <div className=\"flex items-center h-[58px] gap-2 px-3 bg-white/5 border border-white/10 rounded-2xl\">\n                  {[1, 2, 3, 4, 5].map((s) => (\n                    <button\n                      key={s}\n                      type=\"button\"\n                      onClick={() => setRating(s)}\n                      className=\"p-1 hover:scale-125 transition-transform\"\n                    >\n                      <Star \n                        size={22} \n                        className={`${s <= rating ? \'fill-planet-mustard text-planet-mustard\' : \'text-white/10\'}`} \n                      />\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            {/* Dynamic Fields */}\n            <AnimatePresence mode=\"wait\">\n              <motion.div\n                key={type}\n                initial={{ opacity: 0, y: 10 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -10 }}\n                className=\"space-y-6\"\n              >\n                {isVisualMedia && (\n                  <div className=\"grid grid-cols-2 gap-6\">\n                    <div>\n                      <label className=\"flex items-center gap-2 text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">\n                        <Calendar size={12} /> Watch Date\n                      </label>\n                      <input\n                        type=\"date\"\n                        value={watchDate}\n                        onChange={(e) => setWatchDate(e.target.value)}\n                        className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"flex items-center gap-2 text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">\n                        <Monitor size={12} /> Platform\n                      </label>\n                      <input\n                        type=\"text\"\n                        value={platform}\n                        onChange={(e) => setPlatform(e.target.value)}\n                        placeholder=\"Netflix, HBO...\"\n                        className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors placeholder:text-zinc-600\"\n                      />\n                    </div>\n                  </div>\n                )}\n\n                {isInteractiveMedia && (\n                  <div className=\"grid grid-cols-2 gap-6\">\n                    <div>\n                      <label className=\"flex items-center gap-2 text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">\n                        <Calendar size={12} /> Start Date\n                      </label>\n                      <input\n                        type=\"date\"\n                        value={startDate}\n                        onChange={(e) => setStartDate(e.target.value)}\n                        className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"flex items-center gap-2 text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">\n                        <Calendar size={12} /> End Date\n                      </label>\n                      <input\n                        type=\"date\"\n                        value={endDate}\n                        onChange={(e) => setEndDate(e.target.value)}\n                        className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors\"\n                      />\n                    </div>\n                  </div>\n                )}\n\n                {type === MediaType.GAME && (\n                  <div>\n                    <label className=\"flex items-center gap-2 text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">\n                      <Cpu size={12} /> Console\n                    </label>\n                    <input\n                      type=\"text\"\n                      value={consoleName}\n                      onChange={(e) => setConsoleName(e.target.value)}\n                      placeholder=\"PS5, Xbox, Switch...\"\n                      className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors placeholder:text-zinc-600\"\n                    />\n                  </div>\n                )}\n              </motion.div>\n            </AnimatePresence>\n\n            <div>\n              <label className=\"block text-[10px] font-black text-zinc-500 uppercase tracking-[0.25em] mb-3\">Notes</label>\n              <textarea\n                value={notes}\n                onChange={(e) => setNotes(e.target.value)}\n                placeholder=\"Log entry details...\"\n                rows={3}\n                className=\"w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-off-white focus:outline-none focus:border-rocket-fire transition-colors resize-none placeholder:text-zinc-600\"\n              />\n            </div>\n          </div>\n\n          <div className=\"pt-6 flex gap-4\">\n            <button\n              type=\"button\"\n              onClick={onClose}\n              className=\"btn-outline flex-1 py-5\"\n            >\n              Abort\n            </button>\n            <button\n              type=\"submit\"\n              className=\"btn-rocket flex-1 py-5\"\n            >\n              Initialize\n            </button>\n          </div>\n        </form>\n      </motion.div>\n    </motion.div>\n  );"
      }
