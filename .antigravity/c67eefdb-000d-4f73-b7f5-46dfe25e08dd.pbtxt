    replacement_chunks {
      target_content: "import React from \'react\';\nimport { LayoutGrid, Archive, BarChart3, PlusCircle, Film, Tv, Book, Gamepad2, Info } from \'lucide-react\';\nimport { ViewType } from \'../types\';\n\ninterface LayoutProps {\n  children: React.ReactNode;\n  currentView: ViewType;\n  onViewChange: (view: ViewType) => void;\n  onAddMedia: () => void;\n}\n\nexport const Layout: React.FC<LayoutProps> = ({ children, currentView, onViewChange, onAddMedia }) => {\n  return (\n    <div className=\"min-h-screen bg-zinc-950 text-zinc-100 font-sans selection:bg-emerald-500/30\">\n      {/* Navigation */}\n      <nav className=\"fixed top-0 left-0 right-0 h-16 bg-zinc-900/80 backdrop-blur-md border-b border-zinc-800 z-50\">\n        <div className=\"max-w-7xl mx-auto px-4 h-full flex items-center justify-between\">\n          <div \n            className=\"flex items-center gap-2 cursor-pointer group\"\n            onClick={() => onViewChange(\'landing\')}\n          >\n            <div className=\"w-8 h-8 bg-white rounded-lg flex items-center justify-center group-hover:rotate-12 transition-transform\">\n              <LayoutGrid className=\"w-5 h-5 text-zinc-900\" />\n            </div>\n            <span className=\"font-semibold text-lg tracking-tight text-white\">Lumina</span>\n          </div>\n\n          <div className=\"hidden md:flex items-center gap-8\">\n            <button \n              onClick={() => onViewChange(\'tracker\')}\n              className={`text-sm font-medium transition-colors ${currentView === \'tracker\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\n            >\n              Tracker\n            </button>\n            <button \n              onClick={() => onViewChange(\'archive\')}\n              className={`text-sm font-medium transition-colors ${currentView === \'archive\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\n            >\n              Archive\n            </button>\n            <button \n              onClick={() => onViewChange(\'analytics\')}\n              className={`text-sm font-medium transition-colors ${currentView === \'analytics\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\n            >\n              Analytics\n            </button>\n          </div>\n\n          <button \n            onClick={onAddMedia}\n            className=\"flex items-center gap-2 bg-white text-zinc-900 px-4 py-2 rounded-full text-sm font-medium hover:bg-zinc-200 transition-all active:scale-95 shadow-sm\"\n          >\n            <PlusCircle className=\"w-4 h-4\" />\n            <span>Add Media</span>\n          </button>\n        </div>\n      </nav>\n\n      {/* Main Content */}\n      <main className=\"pt-24 pb-12 px-4 max-w-7xl mx-auto\">\n        {children}\n      </main>\n\n      {/* Footer */}\n      <footer className=\"border-t border-zinc-800 py-12 bg-zinc-950\">\n        <div className=\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8\">\n          <div className=\"flex items-center gap-2 opacity-30\">\n            <LayoutGrid className=\"w-4 h-4\" />\n            <span className=\"text-xs font-mono uppercase tracking-widest\">Lumina Media Tracker</span>\n          </div>\n          <div className=\"flex gap-8 text-xs font-medium text-zinc-500\">\n            <span className=\"hover:text-white cursor-pointer transition-colors\">Privacy</span>\n            <span className=\"hover:text-white cursor-pointer transition-colors\">Terms</span>\n            <span className=\"hover:text-white cursor-pointer transition-colors\">API</span>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n};\n"
      replacement_content: "import React from \'react\';\nimport { LayoutGrid, PlusCircle, Rocket } from \'lucide-react\';\nimport { ViewType } from \'../types\';\n\ninterface LayoutProps {\n  children: React.ReactNode;\n  currentView: ViewType;\n  onViewChange: (view: ViewType) => void;\n  onAddMedia: () => void;\n}\n\nexport const Layout: React.FC<LayoutProps> = ({ children, currentView, onViewChange, onAddMedia }) => {\n  return (\n    <div className=\"min-h-screen font-sans selection:bg-rocket-fire/30\">\n      {/* Star Background Animation */}\n      <div className=\"stars-container\">\n        {[...Array(50)].map((_, i) => (\n          <div \n            key={i} \n            className=\"star\"\n            style={{\n              width: Math.random() * 2 + \'px\',\n              height: Math.random() * 2 + \'px\',\n              left: Math.random() * 100 + \'%\',\n              top: Math.random() * 100 + \'%\',\n              animationDuration: Math.random() * 50 + 50 + \'s\',\n              animationDelay: Math.random() * -100 + \'s\'\n            }}\n          />\n        ))}\n      </div>\n\n      {/* Navigation */}\n      <nav className=\"fixed top-0 left-0 right-0 h-16 bg-space-bg/80 backdrop-blur-md border-b border-white/5 z-50\">\n        <div className=\"max-w-7xl mx-auto px-4 h-full flex items-center justify-between\">\n          <div \n            className=\"flex items-center gap-2 cursor-pointer group\"\n            onClick={() => onViewChange(\'landing\')}\n          >\n            <div className=\"w-10 h-10 bg-rocket-fire rounded-full flex items-center justify-center group-hover:rotate-12 transition-transform shadow-[0_0_15px_rgba(255,77,0,0.3)]\">\n              <Rocket className=\"w-5 h-5 text-white\" />\n            </div>\n            <span className=\"font-bold text-xl tracking-tight text-off-white\">Lumen</span>\n          </div>\n\n          <div className=\"hidden md:flex items-center gap-8\">\n            <button \n              onClick={() => onViewChange(\'tracker\')}\n              className={`text-sm font-bold uppercase tracking-widest transition-colors ${currentView === \'tracker\' ? \'text-rocket-fire\' : \'text-zinc-400 hover:text-off-white\'}`}\n            >\n              Tracker\n            </button>\n            <button \n              onClick={() => onViewChange(\'archive\')}\n              className={`text-sm font-bold uppercase tracking-widest transition-colors ${currentView === \'archive\' ? \'text-rocket-fire\' : \'text-zinc-400 hover:text-off-white\'}`}\n            >\n              Archive\n            </button>\n            <button \n              onClick={() => onViewChange(\'analytics\')}\n              className={`text-sm font-bold uppercase tracking-widest transition-colors ${currentView === \'analytics\' ? \'text-rocket-fire\' : \'text-zinc-400 hover:text-off-white\'}`}\n            >\n              Analytics\n            </button>\n          </div>\n\n          <button \n            onClick={onAddMedia}\n            className=\"btn-rocket flex items-center gap-2 px-6 py-2 text-sm\"\n          >\n            <PlusCircle className=\"w-4 h-4\" />\n            <span>Add Media</span>\n          </button>\n        </div>\n      </nav>\n\n      {/* Main Content */}\n      <main className=\"pt-24 pb-12 px-4 max-w-7xl mx-auto relative z-10\">\n        {children}\n      </main>\n\n      {/* Footer */}\n      <footer className=\"border-t border-white/5 py-12 bg-space-bg/50 backdrop-blur-sm\">\n        <div className=\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8\">\n          <div className=\"flex items-center gap-2 opacity-30\">\n            <Rocket className=\"w-4 h-4\" />\n            <span className=\"text-xs font-mono uppercase tracking-widest\">Lumen Space Tracker</span>\n          </div>\n          <div className=\"flex gap-8 text-xs font-medium text-zinc-500\">\n            <span className=\"hover:text-off-white cursor-pointer transition-colors\">Privacy</span>\n            <span className=\"hover:text-off-white cursor-pointer transition-colors\">Terms</span>\n            <span className=\"hover:text-off-white cursor-pointer transition-colors\">API</span>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n};\n"
    }
