    replacement_chunks {
      target_content: "import React from \'react\';\nimport { motion } from \'motion/react\';\nimport { Film, Tv, Book, Gamepad2, ArrowRight } from \'lucide-react\';\nimport { ViewType } from \'../types\';\n\ninterface HeroProps {\n  onStart: (view: ViewType) => void;\n}\n\nexport const Hero: React.FC<HeroProps> = ({ onStart }) => {\n  return (\n    <div className=\"relative overflow-hidden rounded-3xl bg-zinc-900 border border-zinc-800 shadow-sm p-8 md:p-16 mb-12\">\n      <div className=\"relative z-10 max-w-2xl\">\n        <motion.div\n          initial={{ opacity: 0, y: 20 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.6 }}\n        >\n          <span className=\"inline-block px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-xs font-bold uppercase tracking-wider mb-6\">\n            Phase 1: Architecture\n          </span>\n          <h1 className=\"text-5xl md:text-7xl font-semibold tracking-tight text-white mb-8 leading-[0.9]\">\n            Catalog your <span className=\"text-zinc-500 italic\">digital</span> universe.\n          </h1>\n          <p className=\"text-lg text-zinc-400 mb-10 leading-relaxed max-w-lg\">\n            A minimalist tracker for your movies, series, books, and games. \n            Beautifully organized, data-driven, and designed for focus.\n          </p>\n          \n          <div className=\"flex flex-wrap gap-4\">\n            <button \n              onClick={() => onStart(\'tracker\')}\n              className=\"px-8 py-4 bg-white text-zinc-900 rounded-2xl font-semibold flex items-center gap-2 hover:bg-zinc-200 transition-all group\"\n            >\n              Get Started\n              <ArrowRight className=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" />\n            </button>\n            <button \n              onClick={() => onStart(\'archive\')}\n              className=\"px-8 py-4 bg-zinc-800 text-white border border-zinc-700 rounded-2xl font-semibold hover:bg-zinc-700 transition-all\"\n            >\n              View Archive\n            </button>\n          </div>\n        </motion.div>\n      </div>\n\n      {/* Decorative Icons */}\n      <div className=\"absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 opacity-[0.05] pointer-events-none hidden lg:block\">\n        <div className=\"grid grid-cols-2 gap-12 rotate-12\">\n          <Film size={240} color=\"white\" />\n          <Tv size={240} color=\"white\" />\n          <Book size={240} color=\"white\" />\n          <Gamepad2 size={240} color=\"white\" />\n        </div>\n      </div>\n\n      {/* Background Pattern */}\n      <div className=\"absolute inset-0 opacity-[0.05] pointer-events-none\" \n           style={{ backgroundImage: \'radial-gradient(#fff 1px, transparent 1px)\', backgroundSize: \'32px 32px\' }}>\n      </div>\n    </div>\n  );\n};\n"
      replacement_content: "import React from \'react\';\nimport { motion } from \'motion/react\';\nimport { Film, Tv, Book, Gamepad2, ArrowRight } from \'lucide-react\';\nimport { ViewType } from \'../types\';\n\ninterface HeroProps {\n  onStart: (view: ViewType) => void;\n}\n\nexport const Hero: React.FC<HeroProps> = ({ onStart }) => {\n  return (\n    <div className=\"relative overflow-hidden rounded-[3rem] bg-white/5 border border-white/10 backdrop-blur-xl p-12 md:p-24 mb-12 text-center\">\n      <div className=\"relative z-10 max-w-3xl mx-auto\">\n        <motion.div\n          initial={{ opacity: 0, y: 30 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, ease: \"easeOut\" }}\n        >\n          <span className=\"inline-block px-4 py-1.5 rounded-full bg-rocket-fire/10 text-rocket-fire text-xs font-black uppercase tracking-[0.2em] mb-8 border border-rocket-fire/20\">\n            Mission Control\n          </span>\n          <h1 className=\"text-7xl md:text-9xl font-black tracking-tighter text-off-white mb-8 leading-[0.85] uppercase\">\n            Galaxis\n          </h1>\n          <p className=\"text-xl text-zinc-400 mb-12 leading-relaxed max-w-xl mx-auto font-medium\">\n            Your personal observatory for digital artifacts. \n            Track movies, books, and games across the infinite void.\n          </p>\n          \n          <div className=\"flex flex-wrap justify-center gap-6\">\n            <button \n              onClick={() => onStart(\'tracker\')}\n              className=\"btn-rocket group flex items-center gap-3 text-lg px-10 py-5\"\n            >\n              Launch Tracker\n              <ArrowRight className=\"w-6 h-6 group-hover:translate-x-2 transition-transform\" />\n            </button>\n            <button \n              onClick={() => onStart(\'archive\')}\n              className=\"btn-outline text-lg px-10 py-5\"\n            >\n              View Archive\n            </button>\n          </div>\n        </motion.div>\n      </div>\n\n      {/* Decorative Elements */}\n      <div className=\"absolute top-0 left-0 w-full h-full pointer-events-none overflow-hidden\">\n        <div className=\"absolute top-10 left-10 w-32 h-32 bg-planet-teal/10 rounded-full blur-3xl animate-pulse\"></div>\n        <div className=\"absolute bottom-10 right-10 w-48 h-48 bg-rocket-fire/5 rounded-full blur-3xl animate-pulse\" style={{ animationDelay: \'1s\' }}></div>\n      </div>\n\n      {/* Decorative Icons */}\n      <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-[0.02] pointer-events-none\">\n        <div className=\"grid grid-cols-2 gap-32 rotate-12 scale-150\">\n          <Film size={200} color=\"white\" />\n          <Tv size={200} color=\"white\" />\n          <Book size={200} color=\"white\" />\n          <Gamepad2 size={200} color=\"white\" />\n        </div>\n      </div>\n    </div>\n  );\n};\n"
    }
