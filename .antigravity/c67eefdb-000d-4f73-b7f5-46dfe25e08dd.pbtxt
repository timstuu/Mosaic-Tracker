      arguments_json: "{\"Instruction\":\"Switch the application to a dark color scheme.\",\"ReplacementChunks\":[{\"ReplacementContent\":\"    <div className=\\\"min-h-screen bg-zinc-950 text-zinc-100 font-sans selection:bg-emerald-500/30\\\">\\n      {/* Navigation */}\\n      <nav className=\\\"fixed top-0 left-0 right-0 h-16 bg-zinc-900/80 backdrop-blur-md border-b border-zinc-800 z-50\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 h-full flex items-center justify-between\\\">\\n          <div \\n            className=\\\"flex items-center gap-2 cursor-pointer group\\\"\\n            onClick={() => onViewChange(\'landing\')}\\n          >\\n            <div className=\\\"w-8 h-8 bg-white rounded-lg flex items-center justify-center group-hover:rotate-12 transition-transform\\\">\\n              <LayoutGrid className=\\\"w-5 h-5 text-zinc-900\\\" />\\n            </div>\\n            <span className=\\\"font-semibold text-lg tracking-tight text-white\\\">Lumina</span>\\n          </div>\\n\\n          <div className=\\\"hidden md:flex items-center gap-8\\\">\\n            <button \\n              onClick={() => onViewChange(\'tracker\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'tracker\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\\n            >\\n              Tracker\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'archive\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'archive\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\\n            >\\n              Archive\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'analytics\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'analytics\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\\n            >\\n              Analytics\\n            </button>\\n          </div>\\n\\n          <button \\n            onClick={() => onViewChange(\'tracker\')}\\n            className=\\\"flex items-center gap-2 bg-white text-zinc-900 px-4 py-2 rounded-full text-sm font-medium hover:bg-zinc-200 transition-all active:scale-95 shadow-sm\\\"\\n          >\\n            <PlusCircle className=\\\"w-4 h-4\\\" />\\n            <span>Add Media</span>\\n          </button>\\n        </div>\\n      </nav>\\n\\n      {/* Main Content */}\\n      <main className=\\\"pt-24 pb-12 px-4 max-w-7xl mx-auto\\\">\\n        {children}\\n      </main>\\n\\n      {/* Footer */}\\n      <footer className=\\\"border-t border-zinc-800 py-12 bg-zinc-950\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8\\\">\\n          <div className=\\\"flex items-center gap-2 opacity-30\\\">\\n            <LayoutGrid className=\\\"w-4 h-4\\\" />\\n            <span className=\\\"text-xs font-mono uppercase tracking-widest\\\">Lumina Media Tracker</span>\\n          </div>\\n          <div className=\\\"flex gap-8 text-xs font-medium text-zinc-500\\\">\\n            <span className=\\\"hover:text-white cursor-pointer transition-colors\\\">Privacy</span>\\n            <span className=\\\"hover:text-white cursor-pointer transition-colors\\\">Terms</span>\\n            <span className=\\\"hover:text-white cursor-pointer transition-colors\\\">API</span>\\n          </div>\\n        </div>\\n      </footer>\\n    </div>\",\"TargetContent\":\"    <div className=\\\"min-h-screen bg-[#f5f5f5] text-zinc-900 font-sans selection:bg-emerald-100\\\">\\n      {/* Navigation */}\\n      <nav className=\\\"fixed top-0 left-0 right-0 h-16 bg-white/80 backdrop-blur-md border-b border-zinc-200 z-50\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 h-full flex items-center justify-between\\\">\\n          <div \\n            className=\\\"flex items-center gap-2 cursor-pointer group\\\"\\n            onClick={() => onViewChange(\'landing\')}\\n          >\\n            <div className=\\\"w-8 h-8 bg-zinc-900 rounded-lg flex items-center justify-center group-hover:rotate-12 transition-transform\\\">\\n              <LayoutGrid className=\\\"w-5 h-5 text-white\\\" />\\n            </div>\\n            <span className=\\\"font-semibold text-lg tracking-tight\\\">Lumina</span>\\n          </div>\\n\\n          <div className=\\\"hidden md:flex items-center gap-8\\\">\\n            <button \\n              onClick={() => onViewChange(\'tracker\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'tracker\' ? \'text-zinc-900\' : \'text-zinc-500 hover:text-zinc-900\'}`}\\n            >\\n              Tracker\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'archive\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'archive\' ? \'text-zinc-900\' : \'text-zinc-500 hover:text-zinc-900\'}`}\\n            >\\n              Archive\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'analytics\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'analytics\' ? \'text-zinc-900\' : \'text-zinc-500 hover:text-zinc-900\'}`}\\n            >\\n              Analytics\\n            </button>\\n          </div>\\n\\n          <button \\n            onClick={() => onViewChange(\'tracker\')}\\n            className=\\\"flex items-center gap-2 bg-zinc-900 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-zinc-800 transition-all active:scale-95 shadow-sm\\\"\\n          >\\n            <PlusCircle className=\\\"w-4 h-4\\\" />\\n            <span>Add Media</span>\\n          </button>\\n        </div>\\n      </nav>\\n\\n      {/* Main Content */}\\n      <main className=\\\"pt-24 pb-12 px-4 max-w-7xl mx-auto\\\">\\n        {children}\\n      </main>\\n\\n      {/* Footer */}\\n      <footer className=\\\"border-t border-zinc-200 py-12 bg-white\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8\\\">\\n          <div className=\\\"flex items-center gap-2 opacity-50\\\">\\n            <LayoutGrid className=\\\"w-4 h-4\\\" />\\n            <span className=\\\"text-xs font-mono uppercase tracking-widest\\\">Lumina Media Tracker</span>\\n          </div>\\n          <div className=\\\"flex gap-8 text-xs font-medium text-zinc-400\\\">\\n            <span className=\\\"hover:text-zinc-900 cursor-pointer transition-colors\\\">Privacy</span>\\n            <span className=\\\"hover:text-zinc-900 cursor-pointer transition-colors\\\">Terms</span>\\n            <span className=\\\"hover:text-zinc-900 cursor-pointer transition-colors\\\">API</span>\\n          </div>\\n        </div>\\n      </footer>\\n    </div>\"}],\"TargetFile\":\"/src/components/Layout.tsx\"}"
