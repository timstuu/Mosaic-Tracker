      arguments_json: "{\"Instruction\":\"Update Layout component with the new space theme, Rocket icon, and Lumen branding.\",\"ReplacementContent\":\"import React from \'react\';\\nimport { LayoutGrid, PlusCircle, Rocket } from \'lucide-react\';\\nimport { ViewType } from \'../types\';\\n\\ninterface LayoutProps {\\n  children: React.ReactNode;\\n  currentView: ViewType;\\n  onViewChange: (view: ViewType) => void;\\n  onAddMedia: () => void;\\n}\\n\\nexport const Layout: React.FC<LayoutProps> = ({ children, currentView, onViewChange, onAddMedia }) => {\\n  return (\\n    <div className=\\\"min-h-screen font-sans selection:bg-rocket-fire/30\\\">\\n      {/* Star Background Animation */}\\n      <div className=\\\"stars-container\\\">\\n        {[...Array(50)].map((_, i) => (\\n          <div \\n            key={i} \\n            className=\\\"star\\\"\\n            style={{\\n              width: Math.random() * 2 + \'px\',\\n              height: Math.random() * 2 + \'px\',\\n              left: Math.random() * 100 + \'%\',\\n              top: Math.random() * 100 + \'%\',\\n              animationDuration: Math.random() * 50 + 50 + \'s\',\\n              animationDelay: Math.random() * -100 + \'s\'\\n            }}\\n          />\\n        ))}\\n      </div>\\n\\n      {/* Navigation */}\\n      <nav className=\\\"fixed top-0 left-0 right-0 h-16 bg-space-bg/80 backdrop-blur-md border-b border-white/5 z-50\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 h-full flex items-center justify-between\\\">\\n          <div \\n            className=\\\"flex items-center gap-2 cursor-pointer group\\\"\\n            onClick={() => onViewChange(\'landing\')}\\n          >\\n            <div className=\\\"w-10 h-10 bg-rocket-fire rounded-full flex items-center justify-center group-hover:rotate-12 transition-transform shadow-[0_0_15px_rgba(255,77,0,0.3)]\\\">\\n              <Rocket className=\\\"w-5 h-5 text-white\\\" />\\n            </div>\\n            <span className=\\\"font-bold text-xl tracking-tight text-off-white\\\">Lumen</span>\\n          </div>\\n\\n          <div className=\\\"hidden md:flex items-center gap-8\\\">\\n            <button \\n              onClick={() => onViewChange(\'tracker\')}\\n              className={`text-sm font-bold uppercase tracking-widest transition-colors ${currentView === \'tracker\' ? \'text-rocket-fire\' : \'text-zinc-400 hover:text-off-white\'}`}\\n            >\\n              Tracker\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'archive\')}\\n              className={`text-sm font-bold uppercase tracking-widest transition-colors ${currentView === \'archive\' ? \'text-rocket-fire\' : \'text-zinc-400 hover:text-off-white\'}`}\\n            >\\n              Archive\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'analytics\')}\\n              className={`text-sm font-bold uppercase tracking-widest transition-colors ${currentView === \'analytics\' ? \'text-rocket-fire\' : \'text-zinc-400 hover:text-off-white\'}`}\\n            >\\n              Analytics\\n            </button>\\n          </div>\\n\\n          <button \\n            onClick={onAddMedia}\\n            className=\\\"btn-rocket flex items-center gap-2 px-6 py-2 text-sm\\\"\\n          >\\n            <PlusCircle className=\\\"w-4 h-4\\\" />\\n            <span>Add Media</span>\\n          </button>\\n        </div>\\n      </nav>\\n\\n      {/* Main Content */}\\n      <main className=\\\"pt-24 pb-12 px-4 max-w-7xl mx-auto relative z-10\\\">\\n        {children}\\n      </main>\\n\\n      {/* Footer */}\\n      <footer className=\\\"border-t border-white/5 py-12 bg-space-bg/50 backdrop-blur-sm\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8\\\">\\n          <div className=\\\"flex items-center gap-2 opacity-30\\\">\\n            <Rocket className=\\\"w-4 h-4\\\" />\\n            <span className=\\\"text-xs font-mono uppercase tracking-widest\\\">Lumen Space Tracker</span>\\n          </div>\\n          <div className=\\\"flex gap-8 text-xs font-medium text-zinc-500\\\">\\n            <span className=\\\"hover:text-off-white cursor-pointer transition-colors\\\">Privacy</span>\\n            <span className=\\\"hover:text-off-white cursor-pointer transition-colors\\\">Terms</span>\\n            <span className=\\\"hover:text-off-white cursor-pointer transition-colors\\\">API</span>\\n          </div>\\n        </div>\\n      </footer>\\n    </div>\\n  );\\n};\\n\",\"TargetContent\":\"import React from \'react\';\\nimport { LayoutGrid, Archive, BarChart3, PlusCircle, Film, Tv, Book, Gamepad2, Info } from \'lucide-react\';\\nimport { ViewType } from \'../types\';\\n\\ninterface LayoutProps {\\n  children: React.ReactNode;\\n  currentView: ViewType;\\n  onViewChange: (view: ViewType) => void;\\n  onAddMedia: () => void;\\n}\\n\\nexport const Layout: React.FC<LayoutProps> = ({ children, currentView, onViewChange, onAddMedia }) => {\\n  return (\\n    <div className=\\\"min-h-screen bg-zinc-950 text-zinc-100 font-sans selection:bg-emerald-500/30\\\">\\n      {/* Navigation */}\\n      <nav className=\\\"fixed top-0 left-0 right-0 h-16 bg-zinc-900/80 backdrop-blur-md border-b border-zinc-800 z-50\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 h-full flex items-center justify-between\\\">\\n          <div \\n            className=\\\"flex items-center gap-2 cursor-pointer group\\\"\\n            onClick={() => onViewChange(\'landing\')}\\n          >\\n            <div className=\\\"w-8 h-8 bg-white rounded-lg flex items-center justify-center group-hover:rotate-12 transition-transform\\\">\\n              <LayoutGrid className=\\\"w-5 h-5 text-zinc-900\\\" />\\n            </div>\\n            <span className=\\\"font-semibold text-lg tracking-tight text-white\\\">Lumina</span>\\n          </div>\\n\\n          <div className=\\\"hidden md:flex items-center gap-8\\\">\\n            <button \\n              onClick={() => onViewChange(\'tracker\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'tracker\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\\n            >\\n              Tracker\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'archive\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'archive\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\\n            >\\n              Archive\\n            </button>\\n            <button \\n              onClick={() => onViewChange(\'analytics\')}\\n              className={`text-sm font-medium transition-colors ${currentView === \'analytics\' ? \'text-white\' : \'text-zinc-400 hover:text-white\'}`}\\n            >\\n              Analytics\\n            </button>\\n          </div>\\n\\n          <button \\n            onClick={onAddMedia}\\n            className=\\\"flex items-center gap-2 bg-white text-zinc-900 px-4 py-2 rounded-full text-sm font-medium hover:bg-zinc-200 transition-all active:scale-95 shadow-sm\\\"\\n          >\\n            <PlusCircle className=\\\"w-4 h-4\\\" />\\n            <span>Add Media</span>\\n          </button>\\n        </div>\\n      </nav>\\n\\n      {/* Main Content */}\\n      <main className=\\\"pt-24 pb-12 px-4 max-w-7xl mx-auto\\\">\\n        {children}\\n      </main>\\n\\n      {/* Footer */}\\n      <footer className=\\\"border-t border-zinc-800 py-12 bg-zinc-950\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8\\\">\\n          <div className=\\\"flex items-center gap-2 opacity-30\\\">\\n            <LayoutGrid className=\\\"w-4 h-4\\\" />\\n            <span className=\\\"text-xs font-mono uppercase tracking-widest\\\">Lumina Media Tracker</span>\\n          </div>\\n          <div className=\\\"flex gap-8 text-xs font-medium text-zinc-500\\\">\\n            <span className=\\\"hover:text-white cursor-pointer transition-colors\\\">Privacy</span>\\n            <span className=\\\"hover:text-white cursor-pointer transition-colors\\\">Terms</span>\\n            <span className=\\\"hover:text-white cursor-pointer transition-colors\\\">API</span>\\n          </div>\\n        </div>\\n      </footer>\\n    </div>\\n  );\\n};\\n\",\"TargetFile\":\"/src/components/Layout.tsx\"}"
    }
    tool_calls {
      id: "e2979fd1-3452-41fa-b934-9b954e503a6b"
      name: "edit_file"
      arguments_json: "{\"Instruction\":\"Update Hero component with centered layout, Galaxis title, and space theme.\",\"ReplacementContent\":\"import React from \'react\';\\nimport { motion } from \'motion/react\';\\nimport { Film, Tv, Book, Gamepad2, ArrowRight } from \'lucide-react\';\\nimport { ViewType } from \'../types\';\\n\\ninterface HeroProps {\\n  onStart: (view: ViewType) => void;\\n}\\n\\nexport const Hero: React.FC<HeroProps> = ({ onStart }) => {\\n  return (\\n    <div className=\\\"relative overflow-hidden rounded-[3rem] bg-white/5 border border-white/10 backdrop-blur-xl p-12 md:p-24 mb-12 text-center\\\">\\n      <div className=\\\"relative z-10 max-w-3xl mx-auto\\\">\\n        <motion.div\\n          initial={{ opacity: 0, y: 30 }}\\n          animate={{ opacity: 1, y: 0 }}\\n          transition={{ duration: 0.8, ease: \\\"easeOut\\\" }}\\n        >\\n          <span className=\\\"inline-block px-4 py-1.5 rounded-full bg-rocket-fire/10 text-rocket-fire text-xs font-black uppercase tracking-[0.2em] mb-8 border border-rocket-fire/20\\\">\\n            Mission Control\\n          </span>\\n          <h1 className=\\\"text-7xl md:text-9xl font-black tracking-tighter text-off-white mb-8 leading-[0.85] uppercase\\\">\\n            Galaxis\\n          </h1>\\n          <p className=\\\"text-xl text-zinc-400 mb-12 leading-relaxed max-w-xl mx-auto font-medium\\\">\\n            Your personal observatory for digital artifacts. \\n            Track movies, books, and games across the infinite void.\\n          </p>\\n          \\n          <div className=\\\"flex flex-wrap justify-center gap-6\\\">\\n            <button \\n              onClick={() => onStart(\'tracker\')}\\n              className=\\\"btn-rocket group flex items-center gap-3 text-lg px-10 py-5\\\"\\n            >\\n              Launch Tracker\\n              <ArrowRight className=\\\"w-6 h-6 group-hover:translate-x-2 transition-transform\\\" />\\n            </button>\\n            <button \\n              onClick={() => onStart(\'archive\')}\\n              className=\\\"btn-outline text-lg px-10 py-5\\\"\\n            >\\n              View Archive\\n            </button>\\n          </div>\\n        </motion.div>\\n      </div>\\n\\n      {/* Decorative Elements */}\\n      <div className=\\\"absolute top-0 left-0 w-full h-full pointer-events-none overflow-hidden\\\">\\n        <div className=\\\"absolute top-10 left-10 w-32 h-32 bg-planet-teal/10 rounded-full blur-3xl animate-pulse\\\"></div>\\n        <div className=\\\"absolute bottom-10 right-10 w-48 h-48 bg-rocket-fire/5 rounded-full blur-3xl animate-pulse\\\" style={{ animationDelay: \'1s\' }}></div>\\n      </div>\\n\\n      {/* Decorative Icons */}\\n      <div className=\\\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-[0.02] pointer-events-none\\\">\\n        <div className=\\\"grid grid-cols-2 gap-32 rotate-12 scale-150\\\">\\n          <Film size={200} color=\\\"white\\\" />\\n          <Tv size={200} color=\\\"white\\\" />\\n          <Book size={200} color=\\\"white\\\" />\\n          <Gamepad2 size={200} color=\\\"white\\\" />\\n        </div>\\n      </div>\\n    </div>\\n  );\\n};\\n\",\"TargetContent\":\"import React from \'react\';\\nimport { motion } from \'motion/react\';\\nimport { Film, Tv, Book, Gamepad2, ArrowRight } from \'lucide-react\';\\nimport { ViewType } from \'../types\';\\n\\ninterface HeroProps {\\n  onStart: (view: ViewType) => void;\\n}\\n\\nexport const Hero: React.FC<HeroProps> = ({ onStart }) => {\\n  return (\\n    <div className=\\\"relative overflow-hidden rounded-3xl bg-zinc-900 border border-zinc-800 shadow-sm p-8 md:p-16 mb-12\\\">\\n      <div className=\\\"relative z-10 max-w-2xl\\\">\\n        <motion.div\\n          initial={{ opacity: 0, y: 20 }}\\n          animate={{ opacity: 1, y: 0 }}\\n          transition={{ duration: 0.6 }}\\n        >\\n          <span className=\\\"inline-block px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-xs font-bold uppercase tracking-wider mb-6\\\">\\n            Phase 1: Architecture\\n          </span>\\n          <h1 className=\\\"text-5xl md:text-7xl font-semibold tracking-tight text-white mb-8 leading-[0.9]\\\">\\n            Catalog your <span className=\\\"text-zinc-500 italic\\\">digital</span> universe.\\n          </h1>\\n          <p className=\\\"text-lg text-zinc-400 mb-10 leading-relaxed max-w-lg\\\">\\n            A minimalist tracker for your movies, series, books, and games. \\n            Beautifully organized, data-driven, and designed for focus.\\n          </p>\\n          \\n          <div className=\\\"flex flex-wrap gap-4\\\">\\n            <button \\n              onClick={() => onStart(\'tracker\')}\\n              className=\\\"px-8 py-4 bg-white text-zinc-900 rounded-2xl font-semibold flex items-center gap-2 hover:bg-zinc-200 transition-all group\\\"\\n            >\\n              Get Started\\n              <ArrowRight className=\\\"w-5 h-5 group-hover:translate-x-1 transition-transform\\\" />\\n            </button>\\n            <button \\n              onClick={() => onStart(\'archive\')}\\n              className=\\\"px-8 py-4 bg-zinc-800 text-white border border-zinc-700 rounded-2xl font-semibold hover:bg-zinc-700 transition-all\\\"\\n            >\\n              View Archive\\n            </button>\\n          </div>\\n        </motion.div>\\n      </div>\\n\\n      {/* Decorative Icons */}\\n      <div className=\\\"absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 opacity-[0.05] pointer-events-none hidden lg:block\\\">\\n        <div className=\\\"grid grid-cols-2 gap-12 rotate-12\\\">\\n          <Film size={240} color=\\\"white\\\" />\\n          <Tv size={240} color=\\\"white\\\" />\\n          <Book size={240} color=\\\"white\\\" />\\n          <Gamepad2 size={240} color=\\\"white\\\" />\\n        </div>\\n      </div>\\n\\n      {/* Background Pattern */}\\n      <div className=\\\"absolute inset-0 opacity-[0.05] pointer-events-none\\\" \\n           style={{ backgroundImage: \'radial-gradient(#fff 1px, transparent 1px)\', backgroundSize: \'32px 32px\' }}>\\n      </div>\\n    </div>\\n  );\\n};\\n\",\"TargetFile\":\"/src/components/Hero.tsx\"}"
    }
    tool_calls {
      id: "a363c1b9-f513-480a-83cd-1ff154bf35c5"
      name: "edit_file"
      arguments_json: "{\"Instruction\":\"Update App.tsx with the new space theme styles, glass cards, and hover effects.\",\"ReplacementContent\":\"  const renderLanding = () => (\\n    <div className=\\\"space-y-16\\\">\\n      <Hero onStart={() => setIsFormOpen(true)} />\\n      \\n      <section>\\n        <div className=\\\"flex items-center justify-between mb-10\\\">\\n          <h2 className=\\\"text-3xl font-bold tracking-tight text-off-white\\\">Recent Artifacts</h2>\\n          <button \\n            onClick={() => setCurrentView(\'archive\')}\\n            className=\\\"text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-rocket-fire transition-colors\\\"\\n          >\\n            Deep Scan\\n          </button>\\n        </div>\\n\\n        {loading ? (\\n          <div className=\\\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\\\">\\n            {[1, 2, 3].map(i => (\\n              <div key={i} className=\\\"h-64 bg-white/5 rounded-[2rem] animate-pulse\\\" />\\n            ))}\\n          </div>\\n        ) : mediaItems.length === 0 ? (\\n          <div className=\\\"glass-card p-16 text-center border-dashed\\\">\\n            <p className=\\\"text-zinc-500 mb-6 text-lg\\\">The void is empty. No artifacts detected.</p>\\n            <button \\n              onClick={() => setIsFormOpen(true)}\\n              className=\\\"text-sm font-black text-rocket-fire uppercase tracking-widest hover:scale-110 transition-transform inline-block\\\"\\n            >\\n              Initialize First Entry\\n            </button>\\n          </div>\\n        ) : (\\n          <div className=\\\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\\\">\\n            {mediaItems.slice(0, 3).map((item) => (\\n              <motion.div\\n                key={item.id}\\n                initial={{ opacity: 0, scale: 0.95 }}\\n                animate={{ opacity: 1, scale: 1 }}\\n                className=\\\"glass-card p-8 group\\\"\\n              >\\n                <div className=\\\"flex justify-between items-start mb-6\\\">\\n                  <div className=\\\"p-3 bg-white/5 rounded-2xl group-hover:bg-rocket-fire group-hover:text-white transition-all duration-500 group-hover:shadow-[0_0_20px_rgba(255,77,0,0.3)]\\\">\\n                    {getIcon(item.type)}\\n                  </div>\\n                  <div className=\\\"flex items-center gap-1\\\">\\n                    {[...Array(5)].map((_, i) => (\\n                      <Star \\n                        key={i} \\n                        className={`w-4 h-4 ${i < item.rating ? \'fill-planet-mustard text-planet-mustard\' : \'text-white/10\'}`} \\n                      />\\n                    ))}\\n                  </div>\\n                </div>\\n                <h3 className=\\\"font-bold text-xl mb-2 line-clamp-1 text-off-white group-hover:text-rocket-fire transition-colors\\\">{item.title}</h3>\\n                \\n                <div className=\\\"space-y-3 mt-6\\\">\\n                  <div className=\\\"flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-zinc-500\\\">\\n                    <span className=\\\"flex items-center gap-1.5\\\">\\n                      {item.status === MediaStatus.COMPLETED ? <CheckCircle2 className=\\\"w-4 h-4 text-planet-teal\\\" /> : <Clock className=\\\"w-4 h-4\\\" />}\\n                      {item.status.replace(\'_\', \' \')}\\n                    </span>\\n                    <span className=\\\"opacity-20\\\">\342\200\242</span>\\n                    <span>{new Date(item.dateAdded).toLocaleDateString()}</span>\\n                  </div>\\n\\n                  {item.platform && (\\n                    <div className=\\\"flex items-center gap-2 text-[10px] font-black text-planet-teal uppercase tracking-[0.15em]\\\">\\n                      <Monitor size={12} /> {item.platform}\\n                    </div>\\n                  )}\\n                  {item.console && (\\n                    <div className=\\\"flex items-center gap-2 text-[10px] font-black text-planet-mustard uppercase tracking-[0.15em]\\\">\\n                      <Cpu size={12} /> {item.console}\\n                    </div>\\n                  )}\\n                </div>\\n              </motion.div>\\n            ))}\\n          </div>\\n        )}\\n      </section>\\n\\n      <section className=\\\"grid grid-cols-1 md:grid-cols-2 gap-8\\\">\\n        <div className=\\\"glass-card p-10 flex flex-col justify-between min-h-[300px] overflow-hidden relative\\\">\\n          <div className=\\\"relative z-10\\\">\\n            <h3 className=\\\"text-2xl font-bold mb-3 text-off-white\\\">Telemetry</h3>\\n            <p className=\\\"text-zinc-500 text-sm font-medium\\\">Visualizing your trajectory through the media void.</p>\\n          </div>\\n          <div className=\\\"flex items-end gap-3 h-32 relative z-10\\\">\\n            {[40, 70, 45, 90, 60, 80, 50].map((h, i) => (\\n              <div key={i} className=\\\"flex-1 bg-rocket-fire/20 rounded-t-lg group-hover:bg-rocket-fire/40 transition-colors\\\" style={{ height: `${h}%` }} />\\n            ))}\\n          </div>\\n          <div className=\\\"absolute -right-10 -bottom-10 w-40 h-40 bg-rocket-fire/5 rounded-full blur-3xl\\\"></div>\\n        </div>\\n        <div className=\\\"glass-card p-10 flex flex-col justify-between min-h-[300px] overflow-hidden relative\\\">\\n          <div className=\\\"relative z-10\\\">\\n            <h3 className=\\\"text-2xl font-bold text-planet-teal mb-3\\\">Star Charts</h3>\\n            <p className=\\\"text-planet-teal/40 text-sm font-medium\\\">Access your full history and filter by sector.</p>\\n          </div>\\n          <div className=\\\"flex -space-x-4 relative z-10\\\">\\n            {[1, 2, 3, 4].map(i => (\\n              <div key={i} className=\\\"w-14 h-14 rounded-full border-4 border-space-bg bg-white/10 flex items-center justify-center text-planet-teal font-black text-sm backdrop-blur-md\\\">\\n                {i}\\n              </div>\\n            ))}\\n            <div className=\\\"w-14 h-14 rounded-full border-4 border-space-bg bg-rocket-fire flex items-center justify-center text-white font-black text-sm shadow-lg shadow-rocket-fire/20\\\">\\n              +\\n            </div>\\n          </div>\\n          <div className=\\\"absolute -right-10 -bottom-10 w-40 h-40 bg-planet-teal/5 rounded-full blur-3xl\\\"></div>\\n        </div>\\n      </section>\\n    </div>\\n  );\",\"TargetContent\":\"  const renderLanding = () => (\\n    <div className=\\\"space-y-12\\\">\\n      <Hero onStart={() => setIsFormOpen(true)} />\\n      \\n      <section>\\n        <div className=\\\"flex items-center justify-between mb-8\\\">\\n          <h2 className=\\\"text-2xl font-semibold tracking-tight text-white\\\">Recent Activity</h2>\\n          <button \\n            onClick={() => setCurrentView(\'archive\')}\\n            className=\\\"text-sm font-medium text-zinc-500 hover:text-white transition-colors\\\"\\n          >\\n            View all\\n          </button>\\n        </div>\\n\\n        {loading ? (\\n          <div className=\\\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\\\">\\n            {[1, 2, 3].map(i => (\\n              <div key={i} className=\\\"h-48 bg-zinc-900 rounded-3xl animate-pulse\\\" />\\n            ))}\\n          </div>\\n        ) : mediaItems.length === 0 ? (\\n          <div className=\\\"bg-zinc-900 border border-dashed border-zinc-800 rounded-3xl p-12 text-center\\\">\\n            <p className=\\\"text-zinc-500 mb-4\\\">No media tracked yet. Start your collection today.</p>\\n            <button \\n              onClick={() => setIsFormOpen(true)}\\n              className=\\\"text-sm font-bold text-white underline underline-offset-4\\\"\\n            >\\n              Add your first item\\n            </button>\\n          </div>\\n        ) : (\\n          <div className=\\\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\\\">\\n            {mediaItems.slice(0, 3).map((item) => (\\n              <motion.div\\n                key={item.id}\\n                initial={{ opacity: 0, scale: 0.95 }}\\n                animate={{ opacity: 1, scale: 1 }}\\n                className=\\\"bg-zinc-900 border border-zinc-800 rounded-3xl p-6 hover:border-zinc-700 transition-all group\\\"\\n              >\\n                <div className=\\\"flex justify-between items-start mb-4\\\">\\n                  <div className=\\\"p-2 bg-zinc-800 rounded-xl group-hover:bg-white group-hover:text-zinc-900 transition-colors\\\">\\n                    {getIcon(item.type)}\\n                  </div>\\n                  <div className=\\\"flex items-center gap-1\\\">\\n                    {[...Array(5)].map((_, i) => (\\n                      <Star \\n                        key={i} \\n                        className={`w-3 h-3 ${i < item.rating ? \'fill-white text-white\' : \'text-zinc-800\'}`} \\n                      />\\n                    ))}\\n                  </div>\\n                </div>\\n                <h3 className=\\\"font-semibold text-lg mb-1 line-clamp-1 text-white\\\">{item.title}</h3>\\n                \\n                <div className=\\\"space-y-2 mt-4\\\">\\n                  <div className=\\\"flex items-center gap-3 text-xs font-medium text-zinc-500\\\">\\n                    <span className=\\\"flex items-center gap-1\\\">\\n                      {item.status === MediaStatus.COMPLETED ? <CheckCircle2 className=\\\"w-3 h-3 text-emerald-400\\\" /> : <Clock className=\\\"w-3 h-3\\\" />}\\n                      {item.status.replace(\'_\', \' \')}\\n                    </span>\\n                    <span>\342\200\242</span>\\n                    <span>{new Date(item.dateAdded).toLocaleDateString()}</span>\\n                  </div>\\n\\n                  {item.platform && (\\n                    <div className=\\\"flex items-center gap-2 text-[10px] font-bold text-zinc-400 uppercase tracking-wider\\\">\\n                      <Monitor size={10} /> {item.platform}\\n                    </div>\\n                  )}\\n                  {item.console && (\\n                    <div className=\\\"flex items-center gap-2 text-[10px] font-bold text-zinc-400 uppercase tracking-wider\\\">\\n                      <Cpu size={10} /> {item.console}\\n                    </div>\\n                  )}\\n                  {(item.watchDate || item.startDate) && (\\n                    <div className=\\\"flex items-center gap-2 text-[10px] font-bold text-zinc-400 uppercase tracking-wider\\\">\\n                      <Calendar size={10} /> {item.watchDate || item.startDate}\\n                    </div>\\n                  )}\\n                </div>\\n              </motion.div>\\n            ))}\\n          </div>\\n        )}\\n      </section>\\n\\n      <section className=\\\"grid grid-cols-1 md:grid-cols-2 gap-6\\\">\\n        <div className=\\\"bg-zinc-900 border border-zinc-800 text-white rounded-3xl p-8 flex flex-col justify-between min-h-[240px]\\\">\\n          <div>\\n            <h3 className=\\\"text-xl font-semibold mb-2\\\">Analytics Preview</h3>\\n            <p className=\\\"text-zinc-500 text-sm\\\">Visualize your consumption habits across all categories.</p>\\n          </div>\\n          <div className=\\\"flex items-end gap-2 h-24\\\">\\n            {[40, 70, 45, 90, 60, 80, 50].map((h, i) => (\\n              <div key={i} className=\\\"flex-1 bg-white/10 rounded-t-sm\\\" style={{ height: `${h}%` }} />\\n            ))}\\n          </div>\\n        </div>\\n        <div className=\\\"bg-emerald-950/30 border border-emerald-900/50 rounded-3xl p-8 flex flex-col justify-between min-h-[240px]\\\">\\n          <div>\\n            <h3 className=\\\"text-xl font-semibold text-emerald-400 mb-2\\\">Quick Archive</h3>\\n            <p className=\\\"text-emerald-500/60 text-sm\\\">Access your full history and filter by month or category.</p>\\n          </div>\\n          <div className=\\\"flex -space-x-3\\\">\\n            {[1, 2, 3, 4].map(i => (\\n              <div key={i} className=\\\"w-12 h-12 rounded-full border-2 border-emerald-950 bg-emerald-900/50 flex items-center justify-center text-emerald-400 font-bold text-xs\\\">\\n                {i}\\n              </div>\\n            ))}\\n            <div className=\\\"w-12 h-12 rounded-full border-2 border-emerald-950 bg-white flex items-center justify-center text-zinc-900 font-bold text-xs\\\">\\n              +\\n            </div>\\n          </div>\\n        </div>\\n      </section>\\n    </div>\\n  );\",\"TargetFile\":\"/src/App.tsx\"}"
