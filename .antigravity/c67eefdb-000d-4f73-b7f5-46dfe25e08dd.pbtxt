nsition-colors\">\n                    {getIcon(item.type)}\n                  </div>\n                  <div className=\"flex items-center gap-1\">\n                    {[...Array(5)].map((_, i) => (\n                      <Star \n                        key={i} \n                        className={`w-3 h-3 ${i < item.rating ? \'fill-white text-white\' : \'text-zinc-800\'}`} \n                      />\n                    ))}\n                  </div>\n                </div>\n                <h3 className=\"font-semibold text-lg mb-1 line-clamp-1 text-white\">{item.title}</h3>\n                \n                <div className=\"space-y-2 mt-4\">\n                  <div className=\"flex items-center gap-3 text-xs font-medium text-zinc-500\">\n                    <span className=\"flex items-center gap-1\">\n                      {item.status === MediaStatus.COMPLETED ? <CheckCircle2 className=\"w-3 h-3 text-emerald-400\" /> : <Clock className=\"w-3 h-3\" />}\n                      {item.status.replace(\'_\', \' \')}\n                    </span>\n                    <span>\342\200\242</span>\n                    <span>{new Date(item.dateAdded).toLocaleDateString()}</span>\n                  </div>\n\n                  {item.platform && (\n                    <div className=\"flex items-center gap-2 text-[10px] font-bold text-zinc-400 uppercase tracking-wider\">\n                      <Monitor size={10} /> {item.platform}\n                    </div>\n                  )}\n                  {item.console && (\n                    <div className=\"flex items-center gap-2 text-[10px] font-bold text-zinc-400 uppercase tracking-wider\">\n                      <Cpu size={10} /> {item.console}\n                    </div>\n                  )}\n                  {(item.watchDate || item.startDate) && (\n                    <div className=\"flex items-center gap-2 text-[10px] font-bold text-zinc-400 uppercase tracking-wider\">\n                      <Calendar size={10} /> {item.watchDate || item.startDate}\n                    </div>\n                  )}\n                </div>\n              </motion.div>\n            ))}\n          </div>\n        )}\n      </section>\n\n      <section className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        <div className=\"bg-zinc-900 border border-zinc-800 text-white rounded-3xl p-8 flex flex-col justify-between min-h-[240px]\">\n          <div>\n            <h3 className=\"text-xl font-semibold mb-2\">Analytics Preview</h3>\n            <p className=\"text-zinc-500 text-sm\">Visualize your consumption habits across all categories.</p>\n          </div>\n          <div className=\"flex items-end gap-2 h-24\">\n            {[40, 70, 45, 90, 60, 80, 50].map((h, i) => (\n              <div key={i} className=\"flex-1 bg-white/10 rounded-t-sm\" style={{ height: `${h}%` }} />\n            ))}\n          </div>\n        </div>\n        <div className=\"bg-emerald-950/30 border border-emerald-900/50 rounded-3xl p-8 flex flex-col justify-between min-h-[240px]\">\n          <div>\n            <h3 className=\"text-xl font-semibold text-emerald-400 mb-2\">Quick Archive</h3>\n            <p className=\"text-emerald-500/60 text-sm\">Access your full history and filter by month or category.</p>\n          </div>\n          <div className=\"flex -space-x-3\">\n            {[1, 2, 3, 4].map(i => (\n              <div key={i} className=\"w-12 h-12 rounded-full border-2 border-emerald-950 bg-emerald-900/50 flex items-center justify-center text-emerald-400 font-bold text-xs\">\n                {i}\n              </div>\n            ))}\n            <div className=\"w-12 h-12 rounded-full border-2 border-emerald-950 bg-white flex items-center justify-center text-zinc-900 font-bold text-xs\">\n              +\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n  );"
        replacement_content: "  const renderLanding = () => (\n    <div className=\"space-y-16\">\n      <Hero onStart={() => setIsFormOpen(true)} />\n      \n      <section>\n        <div className=\"flex items-center justify-between mb-10\">\n          <h2 className=\"text-3xl font-bold tracking-tight text-off-white\">Recent Artifacts</h2>\n          <button \n            onClick={() => setCurrentView(\'archive\')}\n            className=\"text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-rocket-fire transition-colors\"\n          >\n            Deep Scan\n          </button>\n        </div>\n\n        {loading ? (\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n            {[1, 2, 3].map(i => (\n              <div key={i} className=\"h-64 bg-white/5 rounded-[2rem] animate-pulse\" />\n            ))}\n          </div>\n        ) : mediaItems.length === 0 ? (\n          <div className=\"glass-card p-16 text-center border-dashed\">\n            <p className=\"text-zinc-500 mb-6 text-lg\">The void is empty. No artifacts detected.</p>\n            <button \n              onClick={() => setIsFormOpen(true)}\n              className=\"text-sm font-black text-rocket-fire uppercase tracking-widest hover:scale-110 transition-transform inline-block\"\n            >\n              Initialize First Entry\n            </button>\n          </div>\n        ) : (\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n            {mediaItems.slice(0, 3).map((item) => (\n              <motion.div\n                key={item.id}\n                initial={{ opacity: 0, scale: 0.95 }}\n                animate={{ opacity: 1, scale: 1 }}\n                className=\"glass-card p-8 group\"\n              >\n                <div className=\"flex justify-between items-start mb-6\">\n                  <div className=\"p-3 bg-white/5 rounded-2xl group-hover:bg-rocket-fire group-hover:text-white transition-all duration-500 group-hover:shadow-[0_0_20px_rgba(255,77,0,0.3)]\">\n                    {getIcon(item.type)}\n                  </div>\n                  <div className=\"flex items-center gap-1\">\n                    {[...Array(5)].map((_, i) => (\n                      <Star \n                        key={i} \n                        className={`w-4 h-4 ${i < item.rating ? \'fill-planet-mustard text-planet-mustard\' : \'text-white/10\'}`} \n                      />\n                    ))}\n                  </div>\n                </div>\n                <h3 className=\"font-bold text-xl mb-2 line-clamp-1 text-off-white group-hover:text-rocket-fire transition-colors\">{item.title}</h3>\n                \n                <div className=\"space-y-3 mt-6\">\n                  <div className=\"flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-zinc-500\">\n                    <span className=\"flex items-center gap-1.5\">\n                      {item.status === MediaStatus.COMPLETED ? <CheckCircle2 className=\"w-4 h-4 text-planet-teal\" /> : <Clock className=\"w-4 h-4\" />}\n                      {item.status.replace(\'_\', \' \')}\n                    </span>\n                    <span className=\"opacity-20\">\342\200\242</span>\n                    <span>{new Date(item.dateAdded).toLocaleDateString()}</span>\n                  </div>\n\n                  {item.platform && (\n                    <div className=\"flex items-center gap-2 text-[10px] font-black text-planet-teal uppercase tracking-[0.15em]\">\n                      <Monitor size={12} /> {item.platform}\n                    </div>\n                  )}\n                  {item.console && (\n                    <div className=\"flex items-center gap-2 text-[10px] font-black text-planet-mustard uppercase tracking-[0.15em]\">\n                      <Cpu size={12} /> {item.console}\n                    </div>\n                  )}\n                </div>\n              </motion.div>\n            ))}\n          </div>\n        )}\n      </section>\n\n      <section className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n        <div className=\"glass-card p-10 flex flex-col justify-between min-h-[300px] overflow-hidden relative\">\n          <div className=\"relative z-10\">\n            <h3 className=\"text-2xl font-bold mb-3 text-off-white\">Telemetry</h3>\n            <p className=\"text-zinc-500 text-sm font-medium\">Visualizing your trajectory through the media void.</p>\n          </div>\n          <div className=\"flex items-end gap-3 h-32 relative z-10\">\n            {[40, 70, 45, 90, 60, 80, 50].map((h, i) => (\n              <div key={i} className=\"flex-1 bg-rocket-fire/20 rounded-t-lg group-hover:bg-rocket-fire/40 transition-colors\" style={{ height: `${h}%` }} />\n            ))}\n          </div>\n          <div className=\"absolute -right-10 -bottom-10 w-40 h-40 bg-rocket-fire/5 rounded-full blur-3xl\"></div>\n        </div>\n        <div className=\"glass-card p-10 flex flex-col justify-between min-h-[300px] overflow-hidden relative\">\n          <div className=\"relative z-10\">\n            <h3 className=\"text-2xl font-bold text-planet-teal mb-3\">Star Charts</h3>\n            <p className=\"text-planet-teal/40 text-sm font-medium\">Access your full history and filter by sector.</p>\n          </div>\n          <div className=\"flex -space-x-4 relative z-10\">\n            {[1, 2, 3, 4].map(i => (\n              <div key={i} className=\"w-14 h-14 rounded-full border-4 border-space-bg bg-white/10 flex items-center justify-center text-planet-teal font-black text-sm backdrop-blur-md\">\n                {i}\n              </div>\n            ))}\n            <div className=\"w-14 h-14 rounded-full border-4 border-space-bg bg-rocket-fire flex items-center justify-center text-white font-black text-sm shadow-lg shadow-rocket-fire/20\">\n              +\n            </div>\n          </div>\n          <div className=\"absolute -right-10 -bottom-10 w-40 h-40 bg-planet-teal/5 rounded-full blur-3xl\"></div>\n        </div>\n      </section>\n    </div>\n  );"
